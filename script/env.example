# Variáveis para postar_stories.py
# Copie para .env ou exporte no terminal antes de rodar

# ID da conta de negócios do Instagram (ig-user-id)
# Obtenha em: Meta for Developers > Seu App > Instagram Graph API
IG_BUSINESS_ACCOUNT_ID=

# Token de acesso de longa duração da API do Instagram
# Obtenha em: Meta for Developers > Ferramentas > Graph API Explorer
INSTAGRAM_ACCESS_TOKEN=

# Para --from-firebase: buscar imagens automaticamente do Firebase
# Caminho para o JSON da service account (Firebase Console > Configurações > Contas de serviço)
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Opcional: bucket customizado (default: meta-stories-planner-storage.firebasestorage.app)
# FIREBASE_STORAGE_BUCKET=seu-projeto.firebasestorage.app
